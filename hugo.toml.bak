baseURL = "https://blog.183112.xyz"
languageCode = "en-us"
title = "Blog"
theme = "PaperMod"

[params]
    defaultTheme = "auto"
    showReadingTime = true
    ShowBreadCrumbs = true
    ShowCodeCopyButtons = true
    ShowFullTextContent = false

    [assets]
        favicon = "/favicon.ico"
        favicon16x16 = "/favicon-32x32.png"
        favicon32x32 = "/favicon-32x32.png"
        apple_touch_icon = "/apple-touch-icon.png"

    [params.label]
        text = "孤岛"
        icon = "/images/debian-logo.svg"
        iconHeight = 35

    [params.homeInfoParams]
        Title = "Welcome To My World"
        Content = "We only live once, and we could go at any time."

[[menu.main]]
    name = "Archive"
    url = "/archives"
    weight = 10
[[menu.main]]
    name = "搜索"
    url = "/search"
    weight = 20
[[menu.main]]
    name = "标签"
    url = "/tags"
    weight = 30

[outputs]
    home = ["HTML", "RSS", "JSON"]
